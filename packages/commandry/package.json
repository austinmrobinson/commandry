{
  "name": "commandry",
  "version": "0.1.0",
  "description": "A typesafe command registry for React apps",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.cjs"
    },
    "./adapters/tinykeys": {
      "types": "./dist/adapters/tinykeys.d.ts",
      "import": "./dist/adapters/tinykeys.mjs",
      "require": "./dist/adapters/tinykeys.cjs"
    },
    "./adapters/hotkeys-js": {
      "types": "./dist/adapters/hotkeys-js.d.ts",
      "import": "./dist/adapters/hotkeys-js.mjs",
      "require": "./dist/adapters/hotkeys-js.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm typecheck && pnpm test"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tinykeys": ">=2.0.0",
    "hotkeys-js": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true },
    "tinykeys": { "optional": true },
    "hotkeys-js": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.7.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tinykeys": "^2.1.0",
    "hotkeys-js": "^3.13.0"
  },
  "author": "Austin Robinson",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/austinmrobinson/commandry.git",
    "directory": "packages/commandry"
  },
  "homepage": "https://github.com/austinmrobinson/commandry#readme",
  "bugs": {
    "url": "https://github.com/austinmrobinson/commandry/issues"
  },
  "sideEffects": false,
  "keywords": [
    "command",
    "registry",
    "react",
    "keyboard",
    "shortcuts",
    "command-palette",
    "typesafe"
  ]
}
